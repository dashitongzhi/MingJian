PLANAGENT_ENV=development
PLANAGENT_DATABASE_URL=postgresql+psycopg://planagent:planagent@localhost:5432/planagent
PLANAGENT_REDIS_URL=redis://localhost:6379/0
PLANAGENT_EVENT_BUS_BACKEND=redis
PLANAGENT_MINIO_ENDPOINT=localhost:9000
PLANAGENT_MINIO_ACCESS_KEY=planagent
PLANAGENT_MINIO_SECRET_KEY=planagent123
PLANAGENT_INLINE_INGEST_DEFAULT=true
PLANAGENT_INLINE_SIMULATION_DEFAULT=true
PLANAGENT_OPENAI_API_KEY=
PLANAGENT_OPENAI_BASE_URL=
PLANAGENT_OPENAI_PRIMARY_MODEL=openai/gpt-5.2
# Experimental candidate, verify with POST /admin/openai/test before using in production:
# PLANAGENT_OPENAI_PRIMARY_MODEL=openai/gpt-5.4
PLANAGENT_OPENAI_EXTRACTION_MODEL=
PLANAGENT_OPENAI_REPORT_MODEL=
PLANAGENT_OPENAI_TIMEOUT_SECONDS=45
PLANAGENT_SQL_ECHO=false
