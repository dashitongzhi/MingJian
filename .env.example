PLANAGENT_ENV=development
PLANAGENT_DATABASE_URL=postgresql+psycopg://planagent:planagent@localhost:5432/planagent
PLANAGENT_REDIS_URL=redis://localhost:6379/0
PLANAGENT_EVENT_BUS_BACKEND=redis
PLANAGENT_MINIO_ENDPOINT=localhost:9000
PLANAGENT_MINIO_ACCESS_KEY=planagent
PLANAGENT_MINIO_SECRET_KEY=planagent123
PLANAGENT_MINIO_SECURE=false
PLANAGENT_MINIO_BUCKET=planagent-snapshots
PLANAGENT_SOURCE_SNAPSHOT_BACKEND=filesystem
PLANAGENT_SOURCE_SNAPSHOT_DIR=source_snapshots
PLANAGENT_ADDITIONAL_RSS_FEEDS=
PLANAGENT_SOURCE_FAILURE_DEGRADED_THRESHOLD=5
PLANAGENT_BACKPRESSURE_PENDING_THRESHOLD=1000
PLANAGENT_GRAPH_EMBEDDING_DIMENSIONS=64
PLANAGENT_ANALYSIS_CACHE_ENABLED=true
PLANAGENT_API_CACHE_TTL_SECONDS=300
PLANAGENT_INLINE_INGEST_DEFAULT=true
PLANAGENT_INLINE_SIMULATION_DEFAULT=true
# Shared fallback for all targets. If role-specific values are blank, targets inherit from
# the nearest configured parent and the effective source is visible via GET /admin/openai/status.
PLANAGENT_OPENAI_API_KEY=
PLANAGENT_OPENAI_BASE_URL=
PLANAGENT_OPENAI_PRIMARY_MODEL=openai/gpt-5.2
PLANAGENT_OPENAI_PRIMARY_API_KEY=
PLANAGENT_OPENAI_PRIMARY_BASE_URL=
# Experimental candidate, verify with POST /admin/openai/test before using in production:
# PLANAGENT_OPENAI_PRIMARY_MODEL=openai/gpt-5.4
PLANAGENT_OPENAI_EXTRACTION_MODEL=
PLANAGENT_OPENAI_EXTRACTION_API_KEY=
PLANAGENT_OPENAI_EXTRACTION_BASE_URL=
# X search inherits from the x_search override first, then extraction, then primary/shared.
PLANAGENT_OPENAI_X_SEARCH_MODEL=
PLANAGENT_OPENAI_X_SEARCH_API_KEY=
PLANAGENT_OPENAI_X_SEARCH_BASE_URL=
PLANAGENT_OPENAI_REPORT_MODEL=
PLANAGENT_OPENAI_REPORT_API_KEY=
PLANAGENT_OPENAI_REPORT_BASE_URL=
PLANAGENT_OPENAI_TIMEOUT_SECONDS=45
PLANAGENT_X_BEARER_TOKEN=
PLANAGENT_X_BASE_URL=https://api.x.com/2
PLANAGENT_WORKER_LEASE_SECONDS=60
PLANAGENT_STREAM_CONSUMER_BLOCK_MS=5000
PLANAGENT_STREAM_CONSUMER_COUNT=10
PLANAGENT_SQL_ECHO=false
