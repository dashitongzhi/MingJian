# =============================================================================
# 明鉴 PlanAgent 配置
# =============================================================================
# 使用前请复制此文件为 .env，并填写实际的配置值
# =============================================================================

# 环境模式
PLANAGENT_ENV=development

# Community 默认只监听本机回环地址，并使用本地单用户会话。
# 如需绑定 0.0.0.0 或其他非回环地址，必须把 REMOTE_ACCESS_ENABLED 设为 true，
# 并配置至少 32 字节的持久化 AUTH_SECRET_KEY。
PLANAGENT_BIND_HOST=127.0.0.1
PLANAGENT_REMOTE_ACCESS_ENABLED=false
PLANAGENT_AUTH_SECRET_KEY=
# 远程模式的首次管理员登录密码；setup.sh 会生成并保存在本地 .env 中。
PLANAGENT_BOOTSTRAP_ADMIN_PASSWORD=
# setup.sh 会生成仅供同一部署内 Vite/Docker 反向代理使用的密钥；不要使用 VITE_ 前缀。
PLANAGENT_LOCAL_PROXY_SECRET=

# 数据库配置（SQLite 用于本地开发，生产环境请使用 PostgreSQL）
PLANAGENT_DATABASE_URL=sqlite+aiosqlite:///./planagent.db
# 示例 PostgreSQL 配置：
# PLANAGENT_DATABASE_URL=postgresql+psycopg://planagent:planagent@localhost:5432/planagent

# Redis 配置（用于事件总线，生产环境建议启用）
# PLANAGENT_REDIS_URL=redis://localhost:6379/0
# PLANAGENT_EVENT_BUS_BACKEND=redis

# MinIO 配置（用于存储快照）
PLANAGENT_MINIO_ENDPOINT=localhost:9000
PLANAGENT_MINIO_ACCESS_KEY=change-me-minio-access-key
PLANAGENT_MINIO_SECRET_KEY=change-me-minio-secret-key
PLANAGENT_MINIO_SECURE=false
PLANAGENT_MINIO_BUCKET=planagent-snapshots

# 内联执行（开发环境建议设为 true，生产环境设为 false）
PLANAGENT_INLINE_INGEST_DEFAULT=true
PLANAGENT_INLINE_SIMULATION_DEFAULT=true

# =============================================================================
# AI 模型配置
# =============================================================================
# 有明确供应商的请使用对应官网地址，自定义的代理地址请参考注释中的示例
# =============================================================================

# -------------------- OpenAI --------------------
# 官方地址: https://api.openai.com/v1
# 文档: https://platform.openai.com/docs
PLANAGENT_OPENAI_API_KEY=
PLANAGENT_OPENAI_BASE_URL=https://api.openai.com/v1

# 主模型配置（用于辩论中的仲裁者等）
PLANAGENT_OPENAI_PRIMARY_API_KEY=
PLANAGENT_OPENAI_PRIMARY_BASE_URL=https://api.openai.com/v1
PLANAGENT_OPENAI_PRIMARY_MODEL=gpt-4o

# 提取模型配置（用于从网页/文档中提取信息）
# PLANAGENT_OPENAI_EXTRACTION_API_KEY=sk-xxxxxx
# PLANAGENT_OPENAI_EXTRACTION_BASE_URL=https://api.openai.com/v1
# PLANAGENT_OPENAI_EXTRACTION_MODEL=gpt-4o-mini

# 报告模型配置（用于生成分析报告）
# PLANAGENT_OPENAI_REPORT_API_KEY=sk-xxxxxx
# PLANAGENT_OPENAI_REPORT_BASE_URL=https://api.openai.com/v1
# PLANAGENT_OPENAI_REPORT_MODEL=gpt-4o

# X (Twitter) 搜索模型配置
# PLANAGENT_OPENAI_X_SEARCH_API_KEY=sk-xxxxxx
# PLANAGENT_OPENAI_X_SEARCH_BASE_URL=https://api.openai.com/v1
# PLANAGENT_OPENAI_X_SEARCH_MODEL=gpt-4o-mini

# -------------------- Anthropic (Claude) --------------------
# 官方地址: https://api.anthropic.com
# 文档: https://docs.anthropic.com
PLANAGENT_ANTHROPIC_API_KEY=
PLANAGENT_ANTHROPIC_BASE_URL=https://api.anthropic.com
PLANAGENT_ANTHROPIC_MODEL=

# MiniMax Anthropic-compatible 临时演示配置：
# PLANAGENT_ANTHROPIC_API_KEY=your-minimax-key
# PLANAGENT_ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
# PLANAGENT_ANTHROPIC_MODEL=MiniMax-M2.7

# -------------------- 自定义代理配置 --------------------
# 如果你使用第三方代理服务，请取消注释并修改
# 注意：确保代理服务兼容 OpenAI API 格式
#
# 示例（使用自定义代理）：
# PLANAGENT_OPENAI_API_KEY=your-proxy-api-key
# PLANAGENT_OPENAI_BASE_URL=https://your-proxy-domain/v1
#
# 示例（使用 Azure OpenAI）：
# PLANAGENT_OPENAI_API_KEY=your-azure-key
# PLANAGENT_OPENAI_BASE_URL=https://your-resource.openai.azure.com/v1

# -------------------- 辩论专用模型 --------------------
# 辩论支持方（Advocate）- 建议使用较强的模型
# PLANAGENT_OPENAI_DEBATE_ADVOCATE_API_KEY=sk-xxxxxx
# PLANAGENT_OPENAI_DEBATE_ADVOCATE_BASE_URL=https://api.openai.com/v1
# PLANAGENT_OPENAI_DEBATE_ADVOCATE_MODEL=gpt-4o

# 辩论挑战方（Challenger）- 建议使用较强的模型
# PLANAGENT_OPENAI_DEBATE_CHALLENGER_API_KEY=sk-xxxxxx
# PLANAGENT_OPENAI_DEBATE_CHALLENGER_BASE_URL=https://api.openai.com/v1
# PLANAGENT_OPENAI_DEBATE_CHALLENGER_MODEL=gpt-4o

# 辩论仲裁方（Arbitrator）- 建议使用较强的模型
# PLANAGENT_OPENAI_DEBATE_ARBITRATOR_API_KEY=sk-xxxxxx
# PLANAGENT_OPENAI_DEBATE_ARBITRATOR_BASE_URL=https://api.openai.com/v1
# PLANAGENT_OPENAI_DEBATE_ARBITRATOR_MODEL=gpt-4o

# -------------------- 旧版 ai.xxread.top 配置（仅供参考）--------------------
# 以下是之前使用的第三方代理配置，现已弃用
# 如需使用，请取消注释并替换为你的实际配置
#
# PLANAGENT_OPENAI_API_KEY=sk-xxxxxx
# PLANAGENT_OPENAI_BASE_URL=https://ai.xxread.top/v1
# PLANAGENT_OPENAI_PRIMARY_API_KEY=sk-xxxxxx
# PLANAGENT_OPENAI_PRIMARY_BASE_URL=https://ai.xxread.top/v1

# =============================================================================
# 其他配置
# =============================================================================

# API 请求超时（秒）
PLANAGENT_OPENAI_TIMEOUT_SECONDS=45

# SQL 日志（开发环境建议关闭）
PLANAGENT_SQL_ECHO=false

# CORS 配置
PLANAGENT_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Worker 配置
PLANAGENT_WORKER_LEASE_SECONDS=60

# MCP Server 配置
PLANAGENT_MCP_ENABLED=false
PLANAGENT_MCP_SERVER_NAME=MingJian MCP Server
PLANAGENT_MCP_SERVER_VERSION=0.1.0
PLANAGENT_MCP_PROTOCOL_VERSION=2024-11-05
PLANAGENT_MCP_TRANSPORT=sse
PLANAGENT_MCP_ROUTE_PREFIX=/mcp
